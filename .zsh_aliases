alias alg=algolia
alias v='f -e nvim' # quick opening files with vim
alias vim="nvim"
alias vi="nvim"
alias g=git
alias fix-package-lock="sed -i '' 's|http://|https://|g' package-lock.json"
alias cat=bat
alias ll='eza -la'
alias http='noglob http'
alias urldecode='python -c "import sys, urllib.parse; print(urllib.parse.unquote(sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read().strip()))"'

tree() {
  local arg has_level=0

  for arg in "$@"; do
    [[ "$arg" == -- ]] && break
    case "$arg" in
      -L|--level|--level=*|-L[0-9]*)
        has_level=1
        break
        ;;
    esac
  done

  if (( has_level )); then
    command eza -T "$@"
  else
    command eza -T -L 2 "$@"
  fi
}


